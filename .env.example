# =============================================================================
# DocBot Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# Embedding Provider: "free_huggingface", "free_watsonx", "paid_openai", "paid_gemini"
EMBEDDING_PROVIDER=free_huggingface

# =============================================================================
# Free Embedding Options
# =============================================================================

# Free HuggingFace (sentence-transformers) - No API key needed
FREE_EMBEDDING_PROVIDER=free_huggingface
FREE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Free IBM WatsonX (requires IBM Cloud account - free Lite tier)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your_ibm_project_id_here
WATSONX_EMBEDDING_MODEL=ibm/slate-125m-english-rtrvr

# =============================================================================
# Paid Embedding Options
# =============================================================================

# OpenAI Embeddings (requires API key from https://platform.openai.com/)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini Embeddings (requires API key from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# LLM Configuration
# =============================================================================

# LLM Provider: "gemini" (free tier available) or "openai" (paid)
LLM_PROVIDER=gemini

# OpenAI LLM Settings
OPENAI_MODEL=gpt-4o-mini

# Gemini LLM Settings
GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# Vector Database
# =============================================================================

CHROMA_PERSIST_DIRECTORY=./chroma_db

# =============================================================================
# Document Processing
# =============================================================================

MAX_FILE_SIZE_MB=50
MAX_TOTAL_SIZE_MB=200
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO
